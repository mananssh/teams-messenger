# ─── Core ────────────────────────────────────────────────────
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR

# ─── Transcription (audio mode only) ────────────────────────
WHISPER_MODEL=base                      # tiny | base | small | medium | large

# ─── LLM ────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2

# ─── Prompt ─────────────────────────────────────────────────
PROMPT_PATH=prompts/system.txt          # relative to project root

# ─── Feature Flags ──────────────────────────────────────────
ENABLE_TEAMS=false
ENABLE_EMAIL=false
ENABLE_JIRA=false
ENABLE_GITHUB=false

# ─── Microsoft Teams / Graph API (required when ENABLE_TEAMS=true) ──
#     Register an Azure AD app → copy Client ID & Tenant ID.
#     Add Delegated permissions: Chat.ReadWrite, Chat.Create,
#     User.Read, User.ReadBasic.All.  First run triggers device-code
#     login; subsequent runs use the cached token.
MS_CLIENT_ID=
MS_TENANT_ID=
MS_TOKEN_CACHE_PATH=.ms_token_cache.json

# ─── Email / SMTP (required when ENABLE_EMAIL=true) ─────────
#     Gmail: enable 2FA → generate an App Password at
#     myaccount.google.com/apppasswords → use it as SMTP_PASSWORD.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=                          # your-email@gmail.com
SMTP_PASSWORD=                          # Gmail App Password (16 chars)
EMAIL_FROM=                             # sender address for draft_email actions
EMAIL_DEFAULT_TO=                       # fallback recipient if none resolved
NOTIFICATION_FROM_EMAIL=meetingsummarizer@gds.ey.com  # sender for meeting summary emails

# ─── Jira Cloud (required when ENABLE_JIRA=true) ────────────
#     Free tier: up to 10 users at atlassian.com.
#     Generate an API token at id.atlassian.com/manage-profile/security/api-tokens.
JIRA_SERVER_URL=                        # https://yoursite.atlassian.net
JIRA_USERNAME=                          # your-email@example.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=                       # e.g. MEET

# ─── GitHub (required when ENABLE_GITHUB=true) ──────────────
#     Create a Personal Access Token (classic, repo scope) at
#     github.com/settings/tokens.
GITHUB_TOKEN=
GITHUB_REPO=                            # owner/repo format
